# Runtime
APP_CONFIG=development
FLASK_APP=wsgi.py
SECRET_KEY=generate-a-unique-64-character-secret
SESSION_COOKIE_SECURE=false
TRUST_PROXY_HEADERS=false
TRUST_PROXY_COUNT=1
ASSET_VERSION=development
PUBLIC_BASE_URL=http://127.0.0.1:5000
LOG_LEVEL=INFO

# PostgreSQL (local SSH tunnel example)
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=wedding_db
DB_USER=wedding_user
DB_PASSWORD=replace-me

# Optional RSVP notifications
RESEND_API_KEY=
RSVP_EMAIL_FROM=Adlin & Prithvi RSVP <rsvp@adlinprithvi.cloud>
RSVP_EMAIL_TO=

# Optional Gunicorn tuning for production
GUNICORN_BIND=unix:/run/wedding/wedding.sock
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=45
